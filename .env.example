# GROQ API Key — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use (do not change unless you know what you're doing)
GROQ_MODEL=llama-3.3-70b-versatile

# Max tokens per agent response
MAX_TOKENS=2048

# Temperature for model creativity (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.7
